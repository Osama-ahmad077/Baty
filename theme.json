{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "1720px",
      "wideSize": "2280px"
    },
    "useRootPaddingAwareAlignments": true,
    "color": {
      "defaultPalette": false,
      "palette": [
        {
          "slug": "background",
          "color": "#F5EBDF",
          "name": "Background"
        },
        {
          "slug": "primary",
          "color": "#111827",
          "name": "Primary"
        },
        {
          "slug": "dark-brown",
          "color": "#2D2424",
          "name": "Dark Brown"
        },
        {
          "slug": "accent-brown",
          "color": "#B85C38",
          "name": "Accent Brown"
        },
        {
          "slug": "soft-gray",
          "color": "#6B7280",
          "name": "Soft Gray"
        },
        {
          "slug": "white",
          "color": "#FFFFFF",
          "name": "White"
        }
      ]
    },
    "typography": {
      "fontFamily": true,
      "fluid": true,
      "defaultFontSizes": false,
      "fontSize": "16px",
      "lineHeight": "1.6",
      "fontFamilies": [
        {
          "name": "Canela medium",
          "slug": "canela-500",
          "fontFamily": "'Canela Deck Trial Medium', sans-serif",
          "fontFace": [
            {
              "fontFamily": "Canela Deck Trial Medium",
              "src": [
                "file:./inc/assets/fonts/canela/CanelaText-medium-Trial.woff"
              ],
              "fontWeight": "500",
              "fontStyle": "normal"
            }
          ]
        },
        {
          "name": "Canela regular",
          "slug": "canela-400",
          "fontFamily": "'Canela Trial Regular', sans-serif",
          "fontFace": [
            {
              "fontFamily": "Canela Trial Regular",
              "src": [
                "file:./inc/assets/fonts/canela/CanelaText-regular-Trial.woff"
              ],
              "fontWeight": "400",
              "fontStyle": "normal"
            }
          ]
        },
        {
          "name": "Manrope",
          "slug": "manrope",
          "fontFamily": "'Manrope', sans-serif",
          "fontFace": [
            {
              "fontFamily": "Manrope",
              "src": [
                "file:./inc/assets/fonts/manrope/Manrope-VariableFont_wght.woff2"
              ],
              "fontWeight": "200 800",
              "fontStyle": "normal"
            }
          ]
        },
        {
          "name": "Fira Code",
          "slug": "fira-code",
          "fontFamily": "'Fira Code', monospace",
          "fontFace": [
            {
              "fontFamily": "Fira Code",
              "src": [
                "file:./inc/assets/fonts/fira-code/FiraCode-VariableFont_wght.woff2"
              ],
              "fontWeight": "300 700",
              "fontStyle": "normal"
            }
          ]
        }
      ],
      "fontSizes": [
        {
          "name": "Small",
          "size": "0.875rem",
          "slug": "small"
        },
        {
          "name": "Medium",
          "size": "1rem",
          "slug": "medium"
        },
        {
          "name": "Large",
          "size": "1.38rem",
          "slug": "large"
        },
        {
          "name": "Extra Large",
          "size": "clamp(1.5rem, 1.1939rem + 1.3061vw, 2.5rem)",
          "slug": "x-large"
        },
        {
          "name": "Extra Extra Large",
          "size": "2.15rem",
          "slug": "xx-large"
        }
      ]
    },
    "spacing": {
      "spacingSizes": [
        {
          "name": "Tiny",
          "size": "10px",
          "slug": "20"
        },
        {
          "name": "X-Small",
          "size": "20px",
          "slug": "30"
        },
        {
          "name": "Small",
          "size": "30px",
          "slug": "40"
        },
        {
          "name": "Regular",
          "size": "clamp(24px, 5vw, 48px)",
          "slug": "50"
        },
        {
          "name": "Large",
          "size": "clamp(24px, 7vw, 70px)",
          "slug": "56"
        },
        {
          "name": "X-Large",
          "size": "clamp(50px, 7vw, 90px)",
          "slug": "70"
        },
        {
          "name": "XX-Large",
          "size": "clamp(70px, 10vw, 140px)",
          "slug": "80"
        }
      ],
      "blockGap": "var(--wp--preset--spacing--50)"
    }
  },
  "templateParts": [
    {
      "area": "header",
      "name": "header",
      "title": "Header"
    },
    {
      "area": "footer",
      "name": "footer",
      "title": "Footer"
    },
    {
      "area": "cardpart",
      "name": "cardpart",
      "title": "Card Part"
    }
  ],
  "styles": {
    "color": {},
    "typography": {
      "fontFamily": true,
      "fontSize": "16px",
      "lineHeight": "1.6"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--canela-400)",
          "fontWeight": "400",
          "lineHeight": "1.2",
          "fontSize": "clamp(24px, 6vw, 48px)"
        },
        "color": {
          "text": "var(--wp--preset--color--dark-brown)"
        }
      },
      "h1": {
        "typography": {
          "fontSize": "clamp(32px, 6vw, 100px)",
          "lineHeight": "1.1"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--white)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--accent-brown)"
          }
        }
      }
    },
    "blocks": {
      "core/paragraph": {
      "typography": {
        "fontFamily": true
      }
    },
      "core/button": {
        "border": {
          "radius": "0px"
        },
        "spacing": {
          "padding": {
            "top": "12px",
            "bottom": "12px",
            "left": "24px",
            "right": "24px"
          }
        },
        "typography": {
          "fontSize": "14px",
          "letterSpacing": "0.05em"
        },
        "color": {
          "background": "var(--wp--preset--color--white)",
          "text": "var(--wp--preset--color--primary)"
        },
        ":hover": {
          "color": {
            "background": "var(--wp--preset--color--primary)",
            "text": "var(--wp--preset--color--white)"
          }
        }
      },
      "core/group": {
        "spacing": {
          "blockGap": "var(--wp--preset--spacing--50)"
        }
      },
      "core/image": {
        "border": {
          "radius": "8px"
        }
      }
    }
  }
}